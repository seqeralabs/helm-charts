{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "extensionResourceName": {
            "type": "string",
            "metadata": {
                "description": "The name of the extension."
            }
        },
        "clusterResourceName": {
            "type": "String",
            "metadata": {
                "description": "The name of the Managed Cluster resource."
            }
        },
        "createNewCluster": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "When set to 'true', creates new AKS cluster. Otherwise, an existing cluster is used."
            }
        },
        "location": {
            "type": "String",
            "metadata": {
                "description": "The location of AKS resource."
            }
        },
        "vmSize": {
            "type": "String",
            "defaultValue": "Standard_DS2_v2",
            "metadata": {
                "description": "VM size"
            }
        },
        "vmEnableAutoScale": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "enable auto scaling"
            }
        },
        "vmCount": {
            "type": "Int",
            "defaultValue": 3,
            "metadata": {
                "description": "VM count"
            }
        },
        "dnsPrefix": {
            "defaultValue": "[concat(parameters('clusterResourceName'),'-dns')]",
            "type": "String",
            "metadata": {
                "description": "Optional DNS prefix to use with hosted Kubernetes API server FQDN."
            }
        },
        "osDiskSizeGB": {
            "defaultValue": 0,
            "minValue": 0,
            "maxValue": 1023,
            "type": "Int",
            "metadata": {
                "description": "Disk size (in GiB) to provision for each of the agent pool nodes. This value ranges from 0 to 1023. Specifying 0 will apply the default disk size for that agentVMSize."
            }
        },
        "kubernetesVersion": {
            "type": "String",
            "defaultValue": "1.32.6",
            "metadata": {
                "description": "The version of Kubernetes."
            }
        },
        "networkPlugin": {
            "defaultValue": "azure",
            "allowedValues": [
                "azure",
                "kubenet"
            ],
            "type": "String",
            "metadata": {
                "description": "Network plugin used for building Kubernetes network."
            }
        },
        "enableRBAC": {
            "defaultValue": true,
            "type": "Bool",
            "metadata": {
                "description": "Boolean flag to turn on and off of RBAC."
            }
        },
        "enablePrivateCluster": {
            "defaultValue": false,
            "type": "Bool",
            "metadata": {
                "description": "Enable private network access to the Kubernetes cluster."
            }
        },
        "osSKU": {
            "type": "string",
            "defaultValue": "AzureLinux",
            "allowedValues": [
                "AzureLinux",
                "Ubuntu"
            ],
            "metadata": {
                "description": "The Linux SKU to use."
            }
        },
        "enableFIPS": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable FIPS. https://learn.microsoft.com/en-us/azure/aks/create-node-pools#fips-enabled-node-pools"
            }
        },
        "global.platformExternalDomain": {
            "type": "String",
            "metadata": {
                "description": "Domain where Seqera Platform will be accessible."
            }
        },
        "platform.licenseString": {
            "type": "securestring",
            "metadata": {
                "description": "License key provided by your Seqera account manager."
            }
        },
        "platform.contactEmail": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Sender email address used for user support notifications."
            }
        },
        "platformDatabase.host": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Hostname of the MySQL database server. Leave empty when provisioning a new database."
            }
        },
        "platformDatabase.port": {
            "type": "Int",
            "defaultValue": 3306,
            "metadata": {
                "description": "Port number for the MySQL database."
            }
        },
        "platformDatabase.name": {
            "type": "String",
            "defaultValue": "tower",
            "metadata": {
                "description": "Name of the MySQL database for Seqera Platform."
            }
        },
        "platformDatabase.username": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "MySQL database username. Leave empty when provisioning a new database."
            }
        },
        "platformDatabase.password": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "MySQL database password. Leave empty when provisioning a new database."
            }
        },
        "platformDatabase.connectionOptions.mariadb[0]": {
            "type": "String",
            "defaultValue": "permitMysqlScheme=true&sslMode=verify-ca",
            "metadata": {
                "description": "JDBC connection options for the MariaDB driver, as key=value pairs separated by '&'."
            }
        },
        "redis.host": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Hostname of the Redis cache server. Leave empty when provisioning a new Redis cache."
            }
        },
        "redis.port": {
            "type": "Int",
            "defaultValue": 6379,
            "metadata": {
                "description": "Port number for the Redis server."
            }
        },
        "redis.password": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Redis password, if the server requires authentication."
            }
        },
        "redis.enableTls": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "Enable TLS encryption when connecting to Redis."
            }
        },
        "platform.smtp.host": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "SMTP server hostname."
            }
        },
        "platform.smtp.port": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "SMTP server port."
            }
        },
        "platform.smtp.user": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Username for SMTP server authentication."
            }
        },
        "platform.smtp.password": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Password for SMTP server authentication."
            }
        },
        "platform.jwtSeedString": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Seed used to sign authentication tokens. Leave empty for auto-generation."
            }
        },
        "platform.cryptoSeedString": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Seed used to encrypt sensitive data in the database. Must remain stable across upgrades."
            }
        },
        "studios.enabled": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable Seqera Studios for interactive data analysis sessions."
            }
        },
        "global.studiosDomain": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Domain where the Studios service listens."
            }
        },
        "studios.redis.host": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Hostname of the Redis server for Studios. Leave empty when provisioning a new Redis cache."
            }
        },
        "studios.redis.port": {
            "type": "Int",
            "defaultValue": 6379,
            "metadata": {
                "description": "Port number for the Studios Redis server."
            }
        },
        "studios.redis.password": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Redis password for Studios."
            }
        },
        "studios.redis.enableTls": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "Enable TLS encryption when connecting to the Studios Redis server."
            }
        },
        "pipeline-optimization.enabled": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable the Pipeline Optimization service."
            }
        },
        "pipeline-optimization.database.host": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Hostname of the MySQL database server for Pipeline Optimization."
            }
        },
        "pipeline-optimization.database.port": {
            "type": "Int",
            "defaultValue": 3306,
            "metadata": {
                "description": "Port number for the Pipeline Optimization MySQL database."
            }
        },
        "pipeline-optimization.database.name": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Name of the MySQL database for Pipeline Optimization."
            }
        },
        "pipeline-optimization.database.username": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "MySQL database username for Pipeline Optimization."
            }
        },
        "pipeline-optimization.database.password": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "MySQL database password for Pipeline Optimization."
            }
        },
        "pipeline-optimization.database.enableTls": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable TLS when connecting to the Pipeline Optimization MySQL database."
            }
        },
        "pipeline-optimization.database.sslNoverify": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "Skip TLS certificate verification for the Pipeline Optimization MySQL database."
            }
        },
        "pipeline-optimization.platformDatabase.enableTls": {
            "type": "Bool",
            "defaultValue": true,
            "metadata": {
                "description": "Enable TLS when connecting to the Platform MySQL database for Pipeline Optimization."
            }
        },
        "pipeline-optimization.platformDatabase.sslNoverify": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "Skip TLS certificate verification for the Platform MySQL database used by Pipeline Optimization."
            }
        },
        "createNewDatabase": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "When true, provisions a new Azure Database for MySQL Flexible Server."
            }
        },
        "mysqlServerName": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Name for the new MySQL Flexible Server resource."
            }
        },
        "mysqlLocation": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Region for the MySQL server."
            }
        },
        "mysqlAdminUsername": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Administrator login name for the MySQL server."
            }
        },
        "mysqlAdminPassword": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Administrator password for the MySQL server."
            }
        },
        "mysqlSkuName": {
            "type": "String",
            "defaultValue": "Standard_D4ds_v4",
            "allowedValues": [
                "Standard_D4ds_v4",
                "Standard_D8ds_v4",
                "Standard_D16ds_v4",
                "Standard_D32ds_v4",
                "Standard_D48ds_v4",
                "Standard_D64ds_v4",
                "Standard_E2ds_v4",
                "Standard_E4ds_v4",
                "Standard_E8ds_v4",
                "Standard_E16ds_v4",
                "Standard_E32ds_v4",
                "Standard_E48ds_v4",
                "Standard_E64ds_v4"
            ],
            "metadata": {
                "description": "SKU for the MySQL Flexible Server compute tier."
            }
        },
        "mysqlStorageSizeGB": {
            "type": "Int",
            "defaultValue": 30,
            "minValue": 30,
            "maxValue": 1024,
            "metadata": {
                "description": "Storage size in GiB for the MySQL Flexible Server."
            }
        },
        "mysqlPlatformDatabaseName": {
            "type": "String",
            "defaultValue": "platform",
            "metadata": {
                "description": "Name of the Platform database to create on the MySQL server."
            }
        },
        "createNewPoDatabase": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "When true, provisions a new Azure Database for MySQL Flexible Server for Pipeline Optimization."
            }
        },
        "poMysqlServerName": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Name for the new Pipeline Optimization MySQL Flexible Server resource."
            }
        },
        "poMysqlLocation": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Region for the Pipeline Optimization MySQL server."
            }
        },
        "poMysqlAdminUsername": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Administrator login name for the Pipeline Optimization MySQL server."
            }
        },
        "poMysqlAdminPassword": {
            "type": "securestring",
            "defaultValue": "",
            "metadata": {
                "description": "Administrator password for the Pipeline Optimization MySQL server."
            }
        },
        "poMysqlSkuName": {
            "type": "String",
            "defaultValue": "Standard_D2ds_v4",
            "allowedValues": [
                "Standard_D2ds_v4",
                "Standard_D4ds_v4",
                "Standard_D8ds_v4"
            ],
            "metadata": {
                "description": "SKU for the Pipeline Optimization MySQL Flexible Server compute tier."
            }
        },
        "poMysqlStorageSizeGB": {
            "type": "Int",
            "defaultValue": 20,
            "minValue": 20,
            "maxValue": 1024,
            "metadata": {
                "description": "Storage size in GiB for the Pipeline Optimization MySQL Flexible Server."
            }
        },
        "poMysqlDatabaseName": {
            "type": "String",
            "defaultValue": "pipeline_optimization",
            "metadata": {
                "description": "Name of the database to create on the Pipeline Optimization MySQL server."
            }
        },
        "createNewRedis": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "When true, provisions a new Azure Cache for Redis for Platform."
            }
        },
        "redisServerName": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Name for the new Platform Redis cache resource."
            }
        },
        "redisLocation": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Region for the Platform Redis cache."
            }
        },
        "redisSkuName": {
            "type": "String",
            "defaultValue": "Balanced_B5",
            "allowedValues": [
                "Balanced_B5",
                "Balanced_B10",
                "Balanced_B20",
                "Balanced_B50",
                "Balanced_B100",
                "Balanced_B150",
                "Balanced_B250"
            ],
            "metadata": {
                "description": "SKU for the Platform Azure Managed Redis instance."
            }
        },
        "createNewStudiosRedis": {
            "type": "Bool",
            "defaultValue": false,
            "metadata": {
                "description": "When true, provisions a new Azure Cache for Redis for Studios."
            }
        },
        "studiosRedisServerName": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Name for the new Studios Redis cache resource."
            }
        },
        "studiosRedisLocation": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Region for the Studios Redis cache."
            }
        },
        "studiosRedisSkuName": {
            "type": "String",
            "defaultValue": "Balanced_B5",
            "allowedValues": [
                "Balanced_B5",
                "Balanced_B10",
                "Balanced_B20",
                "Balanced_B50",
                "Balanced_B100",
                "Balanced_B150",
                "Balanced_B250"
            ],
            "metadata": {
                "description": "SKU for the Studios Azure Managed Redis instance."
            }
        }
    },
    "variables": {
        "plan-name": "DONOTMODIFY",
        "plan-publisher": "DONOTMODIFY",
        "plan-offerID": "DONOTMODIFY",
        "releaseTrain": "DONOTMODIFY",
        "clusterExtensionTypeName": "DONOTMODIFY",
        "mysqlEffectiveLocation": "[if(empty(parameters('mysqlLocation')), parameters('location'), parameters('mysqlLocation'))]",
        "mysqlSkuTier": "[if(startsWith(parameters('mysqlSkuName'), 'Standard_E'), 'MemoryOptimized', 'GeneralPurpose')]",
        "redisEffectiveLocation": "[if(empty(parameters('redisLocation')), parameters('location'), parameters('redisLocation'))]",
        "studiosRedisEffectiveLocation": "[if(empty(parameters('studiosRedisLocation')), parameters('location'), parameters('studiosRedisLocation'))]",
        "poMysqlEffectiveLocation": "[if(empty(parameters('poMysqlLocation')), parameters('location'), parameters('poMysqlLocation'))]",
        "provisionPlatformDatabase": "[parameters('createNewDatabase')]",
        "provisionPoServer": "[and(parameters('createNewPoDatabase'), parameters('pipeline-optimization.enabled'))]",
        "platformDbHost": "[if(parameters('createNewDatabase'), reference(parameters('mysqlServerName'), '2023-12-30').fullyQualifiedDomainName, parameters('platformDatabase.host'))]",
        "platformDbUsername": "[if(parameters('createNewDatabase'), parameters('mysqlAdminUsername'), parameters('platformDatabase.username'))]",
        "platformDbPassword": "[if(parameters('createNewDatabase'), parameters('mysqlAdminPassword'), parameters('platformDatabase.password'))]",
        "platformDbName": "[if(parameters('createNewDatabase'), parameters('mysqlPlatformDatabaseName'), parameters('platformDatabase.name'))]",
        "poDbHost": "[if(parameters('createNewPoDatabase'), reference(parameters('poMysqlServerName'), '2023-12-30').fullyQualifiedDomainName, parameters('pipeline-optimization.database.host'))]",
        "poDbName": "[if(parameters('createNewPoDatabase'), parameters('poMysqlDatabaseName'), parameters('pipeline-optimization.database.name'))]",
        "poDbUsername": "[if(parameters('createNewPoDatabase'), parameters('poMysqlAdminUsername'), parameters('pipeline-optimization.database.username'))]",
        "poDbPassword": "[if(parameters('createNewPoDatabase'), parameters('poMysqlAdminPassword'), parameters('pipeline-optimization.database.password'))]",
        "redisHost": "[if(parameters('createNewRedis'), reference(parameters('redisServerName'), '2024-10-01').hostName, parameters('redis.host'))]",
        "redisPort": "[if(parameters('createNewRedis'), 10000, parameters('redis.port'))]",
        "redisEnableTls": "[if(parameters('createNewRedis'), true, parameters('redis.enableTls'))]",
        "studiosRedisHost": "[if(parameters('createNewStudiosRedis'), reference(parameters('studiosRedisServerName'), '2024-10-01').hostName, parameters('studios.redis.host'))]",
        "studiosRedisPort": "[if(parameters('createNewStudiosRedis'), 10000, parameters('studios.redis.port'))]",
        "studiosRedisEnableTls": "[if(parameters('createNewStudiosRedis'), true, parameters('studios.redis.enableTls'))]"
    },
    "resources": [
        {
            "type": "Microsoft.ContainerService/managedClusters",
            "condition": "[parameters('createNewCluster')]",
            "apiVersion": "2025-05-01",
            "name": "[parameters('clusterResourceName')]",
            "location": "[parameters('location')]",
            "dependsOn": [],
            "tags": {},
            "sku": {
                "name": "Base",
                "tier": "Free"
            },
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "kubernetesVersion": "[parameters('kubernetesVersion')]",
                "enableRBAC": "[parameters('enableRBAC')]",
                "dnsPrefix": "[parameters('dnsPrefix')]",
                "autoUpgradeProfile": {
                    "upgradeChannel": "patch",
                    "nodeOSUpgradeChannel": "NodeImage"
                },
                "agentPoolProfiles": [
                    {
                        "name": "agentpool",
                        "osDiskSizeGB": "[parameters('osDiskSizeGB')]",
                        "count": "[parameters('vmCount')]",
                        "enableAutoScaling": "[parameters('vmEnableAutoScale')]",
                        "enableFIPS": "[parameters('enableFIPS')]",
                        "minCount": "[if(parameters('vmEnableAutoScale'), 1, json('null'))]",
                        "maxCount": "[if(parameters('vmEnableAutoScale'), 10, json('null'))]",
                        "vmSize": "[parameters('vmSize')]",
                        "osType": "Linux",
                        "osSKU": "[parameters('osSKU')]",
                        "type": "VirtualMachineScaleSets",
                        "mode": "System",
                        "maxPods": 110,
                        "availabilityZones": [],
                        "enableNodePublicIP": false,
                        "tags": {}
                    }
                ],
                "networkProfile": {
                    "loadBalancerSku": "standard",
                    "networkPlugin": "[parameters('networkPlugin')]"
                },
                "apiServerAccessProfile": {
                    "enablePrivateCluster": "[parameters('enablePrivateCluster')]"
                }
            }
        },
        {
            "type": "Microsoft.DBforMySQL/flexibleServers",
            "condition": "[parameters('createNewDatabase')]",
            "apiVersion": "2023-12-30",
            "name": "[parameters('mysqlServerName')]",
            "location": "[variables('mysqlEffectiveLocation')]",
            "sku": {
                "name": "[parameters('mysqlSkuName')]",
                "tier": "[variables('mysqlSkuTier')]"
            },
            "properties": {
                "administratorLogin": "[parameters('mysqlAdminUsername')]",
                "administratorLoginPassword": "[parameters('mysqlAdminPassword')]",
                "storage": {
                    "storageSizeGB": "[parameters('mysqlStorageSizeGB')]",
                    "autoGrow": "Enabled"
                },
                "backup": {
                    "backupRetentionDays": 7,
                    "geoRedundantBackup": "Disabled"
                },
                "highAvailability": {
                    "mode": "Disabled"
                },
                "version": "8.0.21"
            }
        },
        {
            "type": "Microsoft.DBforMySQL/flexibleServers/databases",
            "condition": "[variables('provisionPlatformDatabase')]",
            "apiVersion": "2023-12-30",
            "name": "[concat(parameters('mysqlServerName'), '/', parameters('mysqlPlatformDatabaseName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.DBforMySQL/flexibleServers', parameters('mysqlServerName'))]"
            ],
            "properties": {
                "charset": "utf8mb4",
                "collation": "utf8mb4_unicode_ci"
            }
        },
        {
            "type": "Microsoft.DBforMySQL/flexibleServers",
            "condition": "[variables('provisionPoServer')]",
            "apiVersion": "2023-12-30",
            "name": "[parameters('poMysqlServerName')]",
            "location": "[variables('poMysqlEffectiveLocation')]",
            "sku": {
                "name": "[parameters('poMysqlSkuName')]",
                "tier": "GeneralPurpose"
            },
            "properties": {
                "administratorLogin": "[parameters('poMysqlAdminUsername')]",
                "administratorLoginPassword": "[parameters('poMysqlAdminPassword')]",
                "storage": {
                    "storageSizeGB": "[parameters('poMysqlStorageSizeGB')]",
                    "autoGrow": "Enabled"
                },
                "backup": {
                    "backupRetentionDays": 7,
                    "geoRedundantBackup": "Disabled"
                },
                "highAvailability": {
                    "mode": "Disabled"
                },
                "version": "8.0.21"
            }
        },
        {
            "type": "Microsoft.DBforMySQL/flexibleServers/databases",
            "condition": "[variables('provisionPoServer')]",
            "apiVersion": "2023-12-30",
            "name": "[concat(parameters('poMysqlServerName'), '/', parameters('poMysqlDatabaseName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.DBforMySQL/flexibleServers', parameters('poMysqlServerName'))]"
            ],
            "properties": {
                "charset": "utf8mb4",
                "collation": "utf8mb4_unicode_ci"
            }
        },
        {
            "type": "Microsoft.Cache/redisEnterprise",
            "condition": "[parameters('createNewRedis')]",
            "apiVersion": "2024-10-01",
            "name": "[parameters('redisServerName')]",
            "location": "[variables('redisEffectiveLocation')]",
            "sku": {
                "name": "[parameters('redisSkuName')]"
            },
            "properties": {
                "minimumTlsVersion": "1.2"
            }
        },
        {
            "type": "Microsoft.Cache/redisEnterprise/databases",
            "condition": "[parameters('createNewRedis')]",
            "apiVersion": "2024-10-01",
            "name": "[concat(parameters('redisServerName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Cache/redisEnterprise', parameters('redisServerName'))]"
            ],
            "properties": {
                "clientProtocol": "Encrypted",
                "clusteringPolicy": "NoCluster",
                "evictionPolicy": "VolatileLRU",
                "port": 10000
            }
        },
        {
            "type": "Microsoft.Cache/redisEnterprise",
            "condition": "[and(parameters('createNewStudiosRedis'), parameters('studios.enabled'))]",
            "apiVersion": "2024-10-01",
            "name": "[parameters('studiosRedisServerName')]",
            "location": "[variables('studiosRedisEffectiveLocation')]",
            "sku": {
                "name": "[parameters('studiosRedisSkuName')]"
            },
            "properties": {
                "minimumTlsVersion": "1.2"
            }
        },
        {
            "type": "Microsoft.Cache/redisEnterprise/databases",
            "condition": "[and(parameters('createNewStudiosRedis'), parameters('studios.enabled'))]",
            "apiVersion": "2024-10-01",
            "name": "[concat(parameters('studiosRedisServerName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Cache/redisEnterprise', parameters('studiosRedisServerName'))]"
            ],
            "properties": {
