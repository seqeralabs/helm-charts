{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy **Seqera Platform** on Azure Kubernetes Service (AKS). This wizard guides you through the essential configuration parameters.",
        "subscription": {
          "resourceProviders": [
            "Microsoft.ContainerService"
          ]
        },
        "location": {
          "label": "Region",
          "visible": "[basics('createNewCluster')]",
          "allowedValues": [
            "eastus",
            "eastus2",
            "centralus",
            "northcentralus",
            "westcentralus",
            "southcentralus",
            "westus",
            "westus2",
            "westus3",
            "canadacentral",
            "canadaeast",
            "brazilsouth",
            "northeurope",
            "westeurope",
            "uksouth",
            "ukwest",
            "francecentral",
            "francesouth",
            "germanywestcentral",
            "norwayeast",
            "switzerlandnorth",
            "swedencentral",
            "uaenorth",
            "southafricanorth",
            "australiaeast",
            "australiasoutheast",
            "southeastasia",
            "eastasia",
            "southindia",
            "centralindia",
            "japaneast",
            "japanwest",
            "koreacentral",
            "koreasouth"
          ]
        },
        "resourceGroup": {
          "allowExisting": true
        }
      }
    },
    "basics": [
      {
        "name": "createNewCluster",
        "type": "Microsoft.Common.OptionsGroup",
        "label": "Create new AKS cluster?",
        "defaultValue": "No",
        "toolTip": "Create a new AKS cluster or use an existing one.",
        "constraints": {
          "allowedValues": [
            {
              "label": "Yes",
              "value": true
            },
            {
              "label": "No",
              "value": false
            }
          ],
          "required": true
        },
        "visible": true
      },
      {
        "name": "existingClusterSection",
        "type": "Microsoft.Common.Section",
        "elements": [
          {
            "name": "clusterLookupControl",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[concat(subscription().id, '/resourcegroups/', resourceGroup().name, '/providers/Microsoft.ContainerService/managedClusters?api-version=2024-09-01')]"
            }
          },
          {
            "name": "existingClusterResourceName",
            "type": "Microsoft.Common.DropDown",
            "label": "AKS Cluster Name",
            "toolTip": "Select an existing AKS cluster from this resource group.",
            "constraints": {
              "allowedValues": "[map(basics('existingClusterSection').clusterLookupControl.value, (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]",
              "required": true
            }
          }
        ],
        "visible": "[equals(basics('createNewCluster'), false)]"
      },
      {
        "name": "newClusterSection",
        "type": "Microsoft.Common.Section",
        "elements": [
          {
            "name": "aksVersionLookupControl",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[concat(subscription().id, '/providers/Microsoft.ContainerService/locations/', location(), '/orchestrators?api-version=2019-04-01&resource-type=managedClusters')]"
            }
          },
          {
            "name": "newClusterResourceName",
            "type": "Microsoft.Common.TextBox",
            "label": "AKS cluster name",
            "defaultValue": "",
            "toolTip": "Use only allowed characters",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9A-Z]{6,30}$",
              "validationMessage": "Only alphanumeric characters are allowed, and the value must be 6-30 characters long."
            }
          },
          {
            "name": "kubernetesVersion",
            "type": "Microsoft.Common.DropDown",
            "label": "Kubernetes version",
            "toolTip": "The version of Kubernetes that should be used for this cluster. You will be able to upgrade this version after creating the cluster.",
            "constraints": {
              "allowedValues": "[map(basics('newClusterSection').aksVersionLookupControl.properties.orchestrators, (item) => parse(concat('{\"label\":\"', item.orchestratorVersion, '\",\"value\":\"', item.orchestratorVersion, '\"}')))]",
              "required": true
            }
          },
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "VM size",
            "toolTip": "The size of virtual machine for VM.",
            "recommendedSizes": [
              "Standard_B4ms",
              "Standard_DS2_v2",
              "Standard_D4s_v3"
            ],
            "constraints": {
              "allowedSizes": [
                "Standard_B4ms",
                "Standard_DS2_v2",
                "Standard_D4s_v3"
              ],
              "excludedSizes": []
            },
            "osPlatform": "Linux"
          },
          {
            "name": "osSKU",
            "type": "Microsoft.Common.DropDown",
            "label": "OS SKU",
            "toolTip": "The SKU of Linux OS for VM.",
            "defaultValue": "AzureLinux",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Ubuntu",
                  "value": "Ubuntu"
                },
                {
                  "label": "AzureLinux",
                  "value": "AzureLinux"
                }
              ],
              "required": true
            }
          },
          {
            "name": "enableAutoScaling",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable auto scaling",
            "toolTip": "Enable auto scaling",
            "defaultValue": true
          },
          {
            "name": "vmCount",
            "type": "Microsoft.Common.Slider",
            "min": 1,
            "max": 10,
            "label": "VMCount",
            "subLabel": "",
            "defaultValue": 3,
            "showStepMarkers": false,
            "toolTip": "Specify VM count",
            "constraints": {
              "required": false
            },
            "visible": true
          }
        ],
        "visible": "[basics('createNewCluster')]"
      }
    ],
    "steps": [
      {
        "name": "platformConfig",
        "label": "Platform Configuration",
        "elements": [
          {
            "name": "platformExternalDomain",
            "type": "Microsoft.Common.TextBox",
            "label": "Platform External Domain",
            "toolTip": "Domain where Seqera Platform will be accessible (e.g. seqera.example.com).",
            "placeholder": "seqera.example.com",
            "constraints": {
              "required": true,
              "regex": "^[a-zA-Z0-9][a-zA-Z0-9.-]+\\.[a-zA-Z]{2,}$",
              "validationMessage": "Must be a valid domain name."
            }
          },
          {
            "name": "licenseString",
            "type": "Microsoft.Common.TextBox",
            "label": "Platform License Key",
            "toolTip": "License key provided by your Seqera account manager.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "extensionResourceName",
            "type": "Microsoft.Common.TextBox",
            "label": "Cluster extension resource name",
            "defaultValue": "seqeraplatform",
            "toolTip": "Only lowercase alphanumeric characters are allowed, and the value must be 6-30 characters long.",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9]{6,30}$",
              "validationMessage": "Only lowercase alphanumeric characters are allowed, and the value must be 6-30 characters long."
            },
            "visible": true
          }
        ]
      },
      {
        "name": "databaseConfig",
        "label": "Database Configuration",
        "elements": [
          {
            "name": "databaseHost",
            "type": "Microsoft.Common.TextBox",
            "label": "MySQL Host",
            "toolTip": "Hostname of the MySQL database server.",
            "placeholder": "mydb.mysql.database.azure.com",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "databasePort",
            "type": "Microsoft.Common.TextBox",
            "label": "MySQL Port",
            "toolTip": "Port number for the MySQL database.",
            "defaultValue": "3306",
            "constraints": {
              "required": true,
              "regex": "^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number."
            }
          },
          {
            "name": "databaseName",
            "type": "Microsoft.Common.TextBox",
            "label": "Database Name",
            "toolTip": "Name of the MySQL database for Seqera Platform.",
            "placeholder": "tower",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "databaseUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Database Username",
            "toolTip": "MySQL database username.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "databasePassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Database Password",
              "confirmPassword": "Confirm Database Password"
            },
            "toolTip": "MySQL database password.",
            "constraints": {
              "required": true
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "databaseConnectionOptionsInfo",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "text": "Additional JDBC connection options for the MariaDB driver, formatted as key=value pairs separated by '&'. See the <a href='https://mariadb.com/docs/connectors/mariadb-connector-j/about-mariadb-connector-j' target='_blank'>MariaDB Connector/J documentation</a> for all available options.",
              "style": "Info"
            }
          },
          {
            "name": "databaseConnectionOptions",
            "type": "Microsoft.Common.TextBox",
            "label": "MySQL Connection Options",
            "toolTip": "JDBC connection options passed to the MariaDB driver, formatted as key=value pairs separated by '&'.",
            "defaultValue": "permitMysqlScheme=true&sslMode=verify-ca",
            "constraints": {
              "required": false
            }
          }
        ]
      },
      {
        "name": "redisConfig",
        "label": "Redis Configuration",
        "elements": [
          {
            "name": "redisClusteringWarning",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "text": "Platform requires a non-clustered Redis endpoint. Ensure your Redis instance is non-clustered.",
              "style": "Warning"
            }
          },
          {
            "name": "redisHost",
            "type": "Microsoft.Common.TextBox",
            "label": "Redis Host",
            "toolTip": "Hostname of the Redis cache server.",
            "placeholder": "myredis.redis.cache.windows.net",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "redisPort",
            "type": "Microsoft.Common.TextBox",
            "label": "Redis Port",
            "toolTip": "Port number for the Redis server.",
            "defaultValue": "6379",
            "constraints": {
              "required": true,
              "regex": "^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number."
            }
          },
          {
            "name": "redisPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Redis Password",
              "confirmPassword": "Confirm Redis Password"
            },
            "toolTip": "Redis password, if the server requires authentication.",
            "constraints": {
              "required": false
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "redisEnableTls",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable TLS for Redis",
            "toolTip": "Enable TLS encryption when connecting to Redis. Recommended.",
            "defaultValue": true
          }
        ]
      },
      {
        "name": "smtpConfig",
        "label": "Email (SMTP) Configuration",
        "elements": [
          {
            "name": "contactEmail",
            "type": "Microsoft.Common.TextBox",
            "label": "Support Contact Email",
            "toolTip": "Sender email address used for user support notifications.",
            "defaultValue": "support@yourdomain.example.com",
            "constraints": {
              "required": false,
              "regex": "^[^@]+@[^@]+\\.[^@]+$",
              "validationMessage": "Must be a valid email address."
            }
          },
          {
            "name": "smtpInfo",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "text": "SMTP settings are required for email-based authentication and event notifications. You can leave these empty and configure them later via Helm values.",
              "style": "Info"
            }
          },
          {
            "name": "smtpHost",
            "type": "Microsoft.Common.TextBox",
            "label": "SMTP Host",
            "toolTip": "SMTP server hostname.",
            "placeholder": "smtp.example.com",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "smtpPort",
            "type": "Microsoft.Common.TextBox",
            "label": "SMTP Port",
            "toolTip": "SMTP server port (e.g. 587 for TLS, 465 for SSL).",
            "placeholder": "587",
            "constraints": {
              "required": false,
              "regex": "^$|^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number or empty."
            }
          },
          {
            "name": "smtpUser",
            "type": "Microsoft.Common.TextBox",
            "label": "SMTP Username",
            "toolTip": "Username for SMTP server authentication.",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "smtpPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "SMTP Password",
              "confirmPassword": "Confirm SMTP Password"
            },
            "toolTip": "Password for SMTP server authentication.",
            "constraints": {
              "required": false
            },
            "options": {
              "hideConfirmation": false
            }
          }
        ]
      },
      {
        "name": "securityConfig",
        "label": "Security Seeds",
        "elements": [
          {
            "name": "securityInfo",
            "type": "Microsoft.Common.InfoBox",
            "options": {
              "text": "Security seeds are used for JWT token signing and database encryption. If left empty, Helm will auto-generate random values. For production, provide stable values that persist across upgrades.",
              "style": "Warning"
            }
          },
          {
            "name": "jwtSeedString",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "JWT Seed",
              "confirmPassword": "Confirm JWT Seed"
            },
            "toolTip": "Seed used to sign authentication tokens. Leave empty for auto-generation.",
            "constraints": {
              "required": false
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "cryptoSeedString",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Crypto Seed",
              "confirmPassword": "Confirm Crypto Seed"
            },
            "toolTip": "Seed used to encrypt sensitive data in the database. Must remain stable across upgrades. Leave empty for auto-generation.",
            "constraints": {
              "required": false
            },
            "options": {
              "hideConfirmation": false
            }
          }
        ]
      },
      {
        "name": "featuresConfig",
        "label": "Extra Features",
        "elements": [
          {
            "name": "studiosEnabled",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable Studios",
            "toolTip": "Enable Seqera Studios for interactive data analysis sessions (Jupyter, VS Code, RStudio).",
            "defaultValue": true
          },
          {
            "name": "studiosDomain",
            "type": "Microsoft.Common.TextBox",
            "label": "Studios Domain",
            "toolTip": "Domain where the Studios service listens. Make sure the TLS certificate covers this and its wildcard subdomains.",
            "defaultValue": "[concat('studios.', steps('platformConfig').platformExternalDomain)]",
            "visible": "[steps('featuresConfig').studiosEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').studiosEnabled]",
              "regex": "^[a-zA-Z0-9][a-zA-Z0-9.-]+\\.[a-zA-Z]{2,}$",
              "validationMessage": "Must be a valid domain name."
            }
          },
          {
            "name": "studiosRedisInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[steps('featuresConfig').studiosEnabled]",
            "options": {
              "text": "Studios requires a dedicated Redis instance, separate from the Platform Redis. Like Platform, Studios only supports a non-clustered Redis endpoint.",
              "style": "Warning"
            }
          },
          {
            "name": "studiosRedisHost",
            "type": "Microsoft.Common.TextBox",
            "label": "Studios Redis Host",
            "toolTip": "Hostname of the Redis server for Studios.",
            "placeholder": "myredis.redis.cache.windows.net",
            "visible": "[steps('featuresConfig').studiosEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').studiosEnabled]"
            }
          },
          {
            "name": "studiosRedisPort",
            "type": "Microsoft.Common.TextBox",
            "label": "Studios Redis Port",
            "toolTip": "Port number for the Studios Redis server.",
            "defaultValue": "6379",
            "visible": "[steps('featuresConfig').studiosEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').studiosEnabled]",
              "regex": "^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number."
            }
          },
          {
            "name": "studiosRedisPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Studios Redis Password",
              "confirmPassword": "Confirm Studios Redis Password"
            },
            "toolTip": "Redis password for Studios, if authentication is required.",
            "visible": "[steps('featuresConfig').studiosEnabled]",
            "constraints": {
              "required": false
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "studiosRedisEnableTls",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable TLS for Studios Redis",
            "toolTip": "Enable TLS encryption when connecting to the Studios Redis server.",
            "visible": "[steps('featuresConfig').studiosEnabled]",
            "defaultValue": true
          },
          {
            "name": "pipelineOptimizationEnabled",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable Pipeline Optimization",
            "toolTip": "Enable the Pipeline Optimization service for automated resource tuning of Nextflow pipelines.",
            "defaultValue": true
          },
          {
            "name": "poDbInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "options": {
              "text": "Pipeline Optimization requires its own dedicated MySQL database, separate from the Platform database.",
              "style": "Info"
            }
          },
          {
            "name": "poDbHost",
            "type": "Microsoft.Common.TextBox",
            "label": "Pipeline Optimization MySQL Host",
            "toolTip": "Hostname of the MySQL database server for Pipeline Optimization.",
            "placeholder": "mydb.mysql.database.azure.com",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            }
          },
          {
            "name": "poDbPort",
            "type": "Microsoft.Common.TextBox",
            "label": "Pipeline Optimization MySQL Port",
            "toolTip": "Port number for the Pipeline Optimization MySQL database.",
            "defaultValue": "3306",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]",
              "regex": "^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number."
            }
          },
          {
            "name": "poDbName",
            "type": "Microsoft.Common.TextBox",
            "label": "Pipeline Optimization Database Name",
            "toolTip": "Name of the MySQL database for Pipeline Optimization.",
            "placeholder": "pipeline_optimization",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            }
          },
          {
            "name": "poDbUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Pipeline Optimization Database Username",
            "toolTip": "MySQL database username for Pipeline Optimization.",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            }
          },
          {
            "name": "poDbPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Pipeline Optimization Database Password",
              "confirmPassword": "Confirm Pipeline Optimization Database Password"
            },
            "toolTip": "MySQL database password for Pipeline Optimization.",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "poDbEnableTls",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable TLS for Pipeline Optimization MySQL",
            "toolTip": "Enable TLS encryption when connecting to the Pipeline Optimization MySQL database. Recommended for Azure Database for MySQL.",
            "defaultValue": true,
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]"
          },
          {
            "name": "poDbSslNoverify",
            "type": "Microsoft.Common.CheckBox",
            "label": "Skip TLS certificate verification (Pipeline Optimization MySQL)",
            "toolTip": "Disable TLS certificate verification. Insecure — for development or testing only.",
            "defaultValue": false,
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]"
          },
          {
            "name": "poPlatformDbInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "options": {
              "text": "Pipeline Optimization also needs read access to the Platform database to read pipeline and job details. A separate user with read-only permissions is recommended, but not required.",
              "style": "Info"
            }
          },
          {
            "name": "poPlatformDbHost",
            "type": "Microsoft.Common.TextBox",
            "label": "Platform MySQL Host (for Pipeline Optimization)",
            "toolTip": "Hostname of the Platform MySQL database. Can be the same as the main Platform database.",
            "placeholder": "mydb.mysql.database.azure.com",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            }
          },
          {
            "name": "poPlatformDbPort",
            "type": "Microsoft.Common.TextBox",
            "label": "Platform MySQL Port (for Pipeline Optimization)",
            "toolTip": "Port number for the Platform MySQL database.",
            "defaultValue": "3306",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]",
              "regex": "^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number."
            }
          },
          {
            "name": "poPlatformDbName",
            "type": "Microsoft.Common.TextBox",
            "label": "Platform Database Name (for Pipeline Optimization)",
            "toolTip": "Name of the Platform MySQL database.",
            "placeholder": "tower",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            }
          },
          {
            "name": "poPlatformDbUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Platform Database Username (for Pipeline Optimization)",
            "toolTip": "MySQL username for Platform database access. A read-only user is sufficient.",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            }
          },
          {
            "name": "poPlatformDbPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Platform Database Password (for Pipeline Optimization)",
              "confirmPassword": "Confirm Platform Database Password"
            },
            "toolTip": "MySQL password for Platform database access.",
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]",
            "constraints": {
              "required": "[steps('featuresConfig').pipelineOptimizationEnabled]"
            },
            "options": {
              "hideConfirmation": false
            }
          },
          {
            "name": "poPlatformDbEnableTls",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable TLS for Platform MySQL (Pipeline Optimization)",
            "toolTip": "Enable TLS encryption when connecting to the Platform MySQL database for Pipeline Optimization.",
            "defaultValue": true,
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]"
          },
          {
            "name": "poPlatformDbSslNoverify",
            "type": "Microsoft.Common.CheckBox",
            "label": "Skip TLS certificate verification (Platform MySQL for Pipeline Optimization)",
            "toolTip": "Disable TLS certificate verification. Insecure — for development or testing only.",
            "defaultValue": false,
            "visible": "[steps('featuresConfig').pipelineOptimizationEnabled]"
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "createNewCluster": "[basics('createNewCluster')]",
      "clusterResourceName": "[if(basics('createNewCluster'), basics('newClusterSection').newClusterResourceName, basics('existingClusterSection').existingClusterResourceName)]",
      "kubernetesVersion": "[basics('newClusterSection').kubernetesVersion]",
      "vmSize": "[basics('newClusterSection').vmSize]",
      "osSKU": "[basics('newClusterSection').osSKU]",
      "vmEnableAutoScale": "[basics('newClusterSection').enableAutoScaling]",
      "vmCount": "[basics('newClusterSection').vmCount]",
      "extensionResourceName": "[steps('platformConfig').extensionResourceName]",
      "global.platformExternalDomain": "[steps('platformConfig').platformExternalDomain]",
      "platform.licenseString": "[steps('platformConfig').licenseString]",
