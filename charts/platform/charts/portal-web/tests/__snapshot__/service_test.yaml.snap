should render complete service with all options using matchSnapshot:
  1: |
    apiVersion: v1
    kind: Service
    metadata:
      annotations: {}
      labels:
        app.kubernetes.io/component: portal-web
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: portal-web
        app.kubernetes.io/version: v9.9.9
        helm.sh/chart: portal-web-1.2.3
      name: release-name-portal-web
      namespace: NAMESPACE
    spec:
      externalTrafficPolicy: Local
      ports:
        - name: custom-http
          nodePort: 30080
          port: 8080
          targetPort: 3000
        - name: metrics
          nodePort: 30090
          port: 9090
          targetPort: 9091
      selector:
        app.kubernetes.io/component: portal-web
      sessionAffinity: ClientIP
      type: NodePort
