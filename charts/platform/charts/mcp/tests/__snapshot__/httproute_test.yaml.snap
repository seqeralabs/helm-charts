should render complete httproute with all options:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      annotations:
        external-dns.alpha.kubernetes.io/hostname: mcp.example.com
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: mcp
        app.kubernetes.io/version: v9.9.9
        environment: production
        helm.sh/chart: mcp-1.2.3
      name: release-name-mcp
      namespace: NAMESPACE
    spec:
      hostnames:
        - mcp.example.com
      parentRefs:
        - name: seqera-gateway
          namespace: gateway-system
          sectionName: https
      rules:
        - backendRefs:
            - name: release-name-mcp
              port: 6010
          matches:
            - path:
                type: PathPrefix
                value: /
  2: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      annotations:
        external-dns.alpha.kubernetes.io/hostname: mcp.example.com
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: mcp
        app.kubernetes.io/version: v9.9.9
        environment: production
        helm.sh/chart: mcp-1.2.3
      name: release-name-mcp-extra-0
      namespace: NAMESPACE
    spec:
      hostnames:
        - api.example.com
      parentRefs:
        - name: seqera-gateway
          namespace: gateway-system
          sectionName: https
      rules:
        - backendRefs:
            - name: api-service
              port: 8080
          matches:
            - path:
                type: PathPrefix
                value: /
