should render a Deployment with default values:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: agent-backend
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: agent-backend
        app.kubernetes.io/version: v9.9.9
        helm.sh/chart: agent-backend-1.2.3
      name: release-name-agent-backend
      namespace: NAMESPACE
    spec:
      selector:
        matchLabels:
          app.kubernetes.io/component: agent-backend
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: agent-backend
      template:
        metadata:
          annotations:
            checksum/configmap: b618bafd2ce627047ebfdfd20f480c0580bb602761ab40768d34d868f0bc6d3b
            checksum/secret: ac4ca92760ab83180bef6b3504a9f7b2663f3c2972a4b7e57a8e3173c6092172
          labels:
            app.kubernetes.io/component: agent-backend
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: agent-backend
            app.kubernetes.io/version: v9.9.9
            helm.sh/chart: agent-backend-1.2.3
        spec:
          containers:
            - env:
                - name: AGENT_BACKEND_DB_PASSWORD
                  valueFrom:
                    secretKeyRef:
                      key: AGENT_BACKEND_DB_PASSWORD
                      name: release-name-agent-backend
                - name: ANTHROPIC_API_KEY
                  valueFrom:
                    secretKeyRef:
                      key: ANTHROPIC_API_KEY
                      name: release-name-agent-backend
                - name: AGENT_BACKEND_TOKEN_ENCRYPTION_KEY
                  valueFrom:
                    secretKeyRef:
                      key: AGENT_BACKEND_TOKEN_ENCRYPTION_KEY
                      name: release-name-agent-backend
              envFrom:
                - configMapRef:
                    name: release-name-agent-backend
              image: private/nf-tower-enterprise/agent-backend:v9.9.9
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 10
                httpGet:
                  path: /health
                  port: 8002
                initialDelaySeconds: 5
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 3
              name: agent-backend
              readinessProbe:
                failureThreshold: 5
                httpGet:
                  path: /health
                  port: 8002
                initialDelaySeconds: 5
                periodSeconds: 5
                successThreshold: 1
                timeoutSeconds: 3
              securityContext:
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 101
              volumeMounts:
                - mountPath: /tmp
                  name: tmp
          initContainers:
            - command:
                - sh
                - -c
                - |
                  echo "$(date): starting check for db $DB_HOST:$DB_PORT"
                  until mysql -h "$DB_HOST" -P "$DB_PORT" -D "$DB_NAME" -u"$DB_USERNAME" -p"$DB_PASSWORD" $MYSQL_EXTRA_ARGS -e "SELECT VERSION()"; do
                    echo "$(date): see you in $SLEEP_PERIOD_SECONDS seconds"
                    sleep $SLEEP_PERIOD_SECONDS
                  done
                  echo "$(date): db server ready"
              env:
                - name: SLEEP_PERIOD_SECONDS
                  value: "5"
                - name: DB_HOST
                  value: ""
                - name: DB_PORT
                  value: "3306"
                - name: DB_NAME
                  value: ""
                - name: DB_USERNAME
                  value: ""
                - name: DB_PASSWORD
                  valueFrom:
                    secretKeyRef:
                      key: AGENT_BACKEND_DB_PASSWORD
                      name: release-name-agent-backend
              image: mysql:9
              imagePullPolicy: IfNotPresent
              name: wait-for-db
              resources:
                limits:
                  memory: 100Mi
                requests:
                  cpu: "0.5"
                  memory: 50Mi
              securityContext:
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 101
            - command:
                - sh
                - -c
                - |
                  echo "$(date): starting check redis '$REDIS_URI' with password (if set) '$REDISCLI_AUTH'";
                  until redis-cli -u "$REDIS_URI" get hello; do
                    echo "$(date): see you in $SLEEP_PERIOD_SECONDS seconds"
                    sleep $SLEEP_PERIOD_SECONDS
                  done
                  echo "$(date): redis server ready"
              env:
                - name: SLEEP_PERIOD_SECONDS
                  value: "5"
                - name: REDIS_URI
                  value: redis://:6379
              image: redis:7-alpine
              imagePullPolicy: IfNotPresent
              name: wait-for-redis
              resources:
                limits:
                  memory: 100Mi
                requests:
                  cpu: "0.5"
                  memory: 50Mi
              securityContext:
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 101
            - command:
                - ./init.sh
              env:
                - name: AGENT_BACKEND_DB_PASSWORD
                  valueFrom:
                    secretKeyRef:
                      key: AGENT_BACKEND_DB_PASSWORD
                      name: release-name-agent-backend
              envFrom:
                - configMapRef:
                    name: release-name-agent-backend
              image: private/nf-tower-enterprise/agent-backend:v9.9.9
              imagePullPolicy: IfNotPresent
              name: init
              resources:
                limits:
                  memory: 100Mi
                requests:
                  cpu: "0.5"
                  memory: 50Mi
              securityContext:
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 101
              volumeMounts:
                - mountPath: /tmp
                  name: tmp
          securityContext:
            fsGroup: 101
          serviceAccountName: release-name-agent-backend-sa
          volumes:
            - emptyDir: {}
              name: tmp
