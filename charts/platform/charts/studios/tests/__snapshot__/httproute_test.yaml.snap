should render complete httproute with all options:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      annotations:
        external-dns.alpha.kubernetes.io/hostname: '*.studios.example.com'
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: studios
        app.kubernetes.io/version: 9.9.9
        environment: production
        helm.sh/chart: studios-1.2.3
      name: release-name-studios
      namespace: NAMESPACE
    spec:
      hostnames:
        - '*.studios.example.com'
      parentRefs:
        - name: seqera-gateway
          namespace: gateway-system
          sectionName: https
      rules:
        - backendRefs:
            - name: release-name-studios-proxy
              port: 80
          matches:
            - path:
                type: PathPrefix
                value: /
  2: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      annotations:
        external-dns.alpha.kubernetes.io/hostname: '*.studios.example.com'
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: studios
        app.kubernetes.io/version: 9.9.9
        environment: production
        helm.sh/chart: studios-1.2.3
      name: release-name-studios-extra-0
      namespace: NAMESPACE
    spec:
      hostnames:
        - api.example.com
      parentRefs:
        - name: seqera-gateway
          namespace: gateway-system
          sectionName: https
      rules:
        - backendRefs:
            - name: api-service
              port: 8080
          matches:
            - path:
                type: PathPrefix
                value: /
